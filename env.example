# 服务器配置
PORT=3001
HOST=0.0.0.0

# 存储配置
STORAGE_PATH=./uploads

# 上传配置（可选，默认值在 config.js 中设置）
# MAX_FILE_SIZE=104857600  # 100MB in bytes
# ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.webp,.bmp,.svg
# THUMBNAIL_WIDTH=0  # 瀑布流缩略图宽度（像素），0 表示使用原图，推荐值 400-800
# AUTO_RENAME_UPLOADS=true  # 上传图片是否自动重命名
# UPLOAD_RENAME_PATTERN=IMG_{datetime}_{random}  # 可用 token: {datetime},{date},{time},{timestamp},{random},{uuid},{name}

# 密码保护配置（可选）
# 设置此环境变量将启用密码保护，用户需要输入密码才能访问系统
PASSWORD=qaz123
# 启用 PASSWORD 后，图片/文件直链默认也需要登录态或分享 token。
# 如果仍希望保持公开图床直链，可显式设置为 true。
# PUBLIC_IMAGE_ACCESS=true

# 环境
NODE_ENV=production
